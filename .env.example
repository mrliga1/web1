# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GitHub synchronization configuration for local file uploads
# ĐỂ TRÁNH GITHUB THU HỒI TOKEN API: Hãy mã hóa Base64 cho Token của bạn rôi thêm tiền tố "base64:"
# Ví dụ thay vì dùng: GITHUB_TOKEN="ghp_123456..." 
# Hãy dùng: GITHUB_TOKEN="" (Hệ thống đã hỗ trợ sẵn việc giải mã)
GITHUB_TOKEN=""
GITHUB_REPO="web1"
GITHUB_OWNER="mrliga1"
GITHUB_BRANCH="main"

SMTP_USER="thuankdbds@gmail.com"
SMTP_PASS="qthi yqro aizm zfza"

# Danh sách IP bị chặn (cách nhau bởi dấu phẩy, ví dụ: 192.168.1.1, 10.0.0.1)
BLOCKED_IPS=""