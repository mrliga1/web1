rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net First
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      allow read, write: if true;
    }

    // Projects / Developments Collection
    match /projects/{projectId} {
      allow read, write: if true;
    }

    // News/Articles Collection
    match /news/{newsId} {
      allow read, write: if true;
    }

    // Consultations / Leads Collection
    match /consultations/{consultationId} {
      allow read, write: if true;
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Layouts Collection
    match /layouts/{layoutId} {
      allow read, write: if true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.time < timestamp.date(2027, 1, 1));
    }
  }
}
