# GitHub – lưu trữ ảnh (dùng khi chạy local với npm run dev)
# Trên Firebase: cấu hình qua Admin > Cài đặt GitHub (lưu vào Firestore)
# Hoặc thêm các biến VITE_* vào GitHub Secrets để inject lúc build CI
VITE_GITHUB_TOKEN=""
VITE_GITHUB_OWNER="mrliga1"
VITE_GITHUB_REPO="web1"
VITE_GITHUB_BRANCH="main"

# Server-side (npm run dev) – dùng cho /api/upload
GITHUB_TOKEN=""
GITHUB_OWNER="mrliga1"
GITHUB_REPO="web1"
GITHUB_BRANCH="main"
